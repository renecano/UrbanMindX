          from="este_entrada" to="oeste_salida"
          begin="0" end="3600" vehsPerHour="300"/>

    <!-- ============================================ -->
    <!-- FASE 2 — HORA PICO: 7am a 9am              -->
    <!-- Maxima congestion — datos reales UAEM 2022  -->
    <!-- ============================================ -->

    <!-- Pino Suarez Norte (3 carriles) -->
    <flow id="pico_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="3600" end="10800" vehsPerHour="1050"/>

    <!-- Pino Suarez Sur (2 carriles) -->
    <flow id="pico_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="3600" end="10800" vehsPerHour="700"/>

    <!-- Venustiano Carranza Oeste (3 carriles) -->
    <flow id="pico_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="3600" end="10800" vehsPerHour="1050"/>

    <!-- Venustiano Carranza Este (2 carriles) -->
    <flow id="pico_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="3600" end="10800" vehsPerHour="700"/>

    <!-- ============================================ -->
    <!-- FASE 3 — POST-PICO: 9am a 12pm             -->
    <!-- ============================================ -->

    <!-- Pino Suarez Norte (3 carriles) -->
    <flow id="post_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="10800" end="21600" vehsPerHour="600"/>

    <!-- Pino Suarez Sur (2 carriles) -->

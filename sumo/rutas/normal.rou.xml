<!--
    normal.rou.xml — v3 CORREGIDA
    Intersección real: Venustiano Carranza × Blvr. Pino Suárez, Toluca
    Coordenadas: 19.2790338, -99.6483286

    Fuente: Caracterización de la Movilidad Urbana en la Ecozona
            de la Ciudad de Toluca, Revista Quivera UAEM 2022.
            Aforos realizados mayo 2021 en Blvr. Pino Suárez.

    Geometría real de la intersección:
        Pino Suárez  (Norte-Sur): norte=3 carriles, sur=2 carriles
        Venustiano Carranza (E-O): oeste=3 carriles, este=2 carriles

    Proporcionalidad de flujo por capacidad de carril (3:2 = 60%:40%):
        Pino Suárez total sentido → norte(3c) recibe 60%, sur(2c) recibe 40%
        Carranza    total sentido → oeste(3c) recibe 60%, este(2c) recibe 40%

    Flujos fuente UAEM (por sentido total de calle):
        Pre-pico  (6am-7am):   Pino Suárez ≈ 760 veh/h  | Carranza ≈ 410 veh/h
        Hora pico (7am-9am):   Pino Suárez ≈ 1750 veh/h | Carranza ≈ 940 veh/h
        Post-pico (9am-12pm):  Pino Suárez ≈ 1050 veh/h | Carranza ≈ 565 veh/h

    Tiempos en segundos:
        0     = 6:00am    |   3600  = 7:00am
        10800 = 9:00am    |   21600 = 12:00pm

    Compatible con: simulacion.sumocfg (begin=0, end=21600)
-->
<routes>

    <vType id="auto_normal"   accel="2.6" decel="4.5" sigma="0.5"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>
    <vType id="auto_autonomo" accel="2.6" decel="4.5" sigma="0.0"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"
           color="0,0,255"/>

    <!-- ================================================ -->
    <!-- PRE-PICO: 6am a 7am (0 – 3600 s)               -->
    <!-- ================================================ -->

    <!-- Pino Suárez Norte (3 carriles → 60% de 760) -->
    <flow id="pre_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="0" end="3600" vehsPerHour="456"/>

    <!-- Pino Suárez Sur (2 carriles → 40% de 760) -->
    <flow id="pre_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="0" end="3600" vehsPerHour="304"/>

    <!-- Venustiano Carranza Oeste (3 carriles → 60% de 410) -->
    <flow id="pre_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="0" end="3600" vehsPerHour="246"/>

    <!-- Venustiano Carranza Este (2 carriles → 40% de 410) -->

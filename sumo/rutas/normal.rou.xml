<!--
    normal.rou.xml — v2
    Interseccion real: Venustiano Carranza y Blvr. Pino Suarez, Toluca
    Coordenadas: 19.2790338, -99.6483286

    Geometria real de la interseccion:
        Pino Suarez (Norte-Sur):
            norte_entrada: 3 carriles (hacia el norte)
            sur_entrada:   2 carriles (hacia el sur)
        Venustiano Carranza (Este-Oeste):
            oeste_entrada: 3 carriles (hacia el oeste)
            este_entrada:  2 carriles (hacia el este)

    Flujos proporcionales a carriles:
        3 carriles = 60% del flujo total de esa calle
        2 carriles = 40% del flujo total de esa calle

    Fuente: Estudio de Movilidad Urbana UAEM 2022
            44.7 vehiculos/minuto = 2,682 veh/hora total
            Distribuido por capacidad de carriles reales

    Perfil temporal:
        Pre-pico  (6am-7am):   norte=450  sur=300  oeste=450  este=300
        Hora pico (7am-9am):   norte=1050 sur=700  oeste=1050 este=700
        Post-pico (9am-12pm):  norte=600  sur=400  oeste=600  este=400
-->
<routes>

    <vType id="auto_normal"   accel="2.6" decel="4.5" sigma="0.5"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>
    <vType id="auto_autonomo" accel="2.6" decel="4.5" sigma="0.0"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"
           color="0,0,255"/>

    <!-- ============================================ -->
    <!-- FASE 1 — PRE-PICO: 6am a 7am               -->
    <!-- ============================================ -->

    <!-- Pino Suarez Norte (3 carriles) -->

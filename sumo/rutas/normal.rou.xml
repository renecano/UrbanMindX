          from="norte_entrada" to="sur_salida"
          begin="0" end="3600" vehsPerHour="450"/>

    <!-- Pino Suarez Sur (2 carriles) -->
    <flow id="pre_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="0" end="3600" vehsPerHour="300"/>

    <!-- Venustiano Carranza Oeste (3 carriles) -->

          from="este_entrada" to="oeste_salida"
          begin="0" end="3600" vehsPerHour="164"/>

    <!-- ================================================ -->
    <!-- HORA PICO: 7am a 9am (3600 – 10800 s)          -->
    <!-- Máxima congestión — datos reales UAEM 2022      -->
    <!-- ================================================ -->

    <!-- Pino Suárez Norte (3 carriles → 60% de 1750) -->
    <flow id="pico_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="3600" end="10800" vehsPerHour="1050"/>

    <!-- Pino Suárez Sur (2 carriles → 40% de 1750) -->
    <flow id="pico_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="3600" end="10800" vehsPerHour="700"/>

    <!-- Venustiano Carranza Oeste (3 carriles → 60% de 940) -->
    <flow id="pico_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="3600" end="10800" vehsPerHour="564"/>

    <!-- Venustiano Carranza Este (2 carriles → 40% de 940) -->
    <flow id="pico_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="3600" end="10800" vehsPerHour="376"/>

    <!-- ================================================ -->
    <!-- POST-PICO: 9am a 12pm (10800 – 21600 s)        -->
    <!-- ================================================ -->

    <!-- Pino Suárez Norte (3 carriles → 60% de 1050) -->
    <flow id="post_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="10800" end="21600" vehsPerHour="630"/>

    <!-- Pino Suárez Sur (2 carriles → 40% de 1050) -->
    <flow id="post_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="10800" end="21600" vehsPerHour="420"/>

    <!-- Venustiano Carranza Oeste (3 carriles → 60% de 565) -->
    <flow id="post_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="10800" end="21600" vehsPerHour="339"/>

    <!-- Venustiano Carranza Este (2 carriles → 40% de 565) -->

<?xml version="1.0" encoding="UTF-8"?>
<!--
    hora_pico.rou.xml — VERSION FINAL
    Interseccion real: Venustiano Carranza y Blvr. Pino Suarez, Toluca
    Fuente: Quivera UAEM 2022 — aforos mayo 2021

    Simula 2 horas de hora pico con rampa de subida y bajada:
        0-30min:  inicio de pico  (70% del maximo)
        30-90min: pico maximo     (100%)
        90-120min: fin de pico    (85%)

    Flujos maximo: Pino Suarez=870  Carranza=470 veh/h por sentido
-->
<routes>

    <vType id="auto_normal"   accel="2.6" decel="4.5" sigma="0.5"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>
    <vType id="auto_autonomo" accel="2.6" decel="4.5" sigma="0.0"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"
           color="0,0,255"/>

    <!-- INICIO DE PICO: 0 a 30 min — 70% del maximo -->
    <!-- Pino=609  Carranza=329 veh/h                -->
    <flow id="inicio_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="0" end="1800" vehsPerHour="609"/>
    <flow id="inicio_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="0" end="1800" vehsPerHour="609"/>
    <flow id="inicio_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="0" end="1800" vehsPerHour="329"/>
    <flow id="inicio_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="0" end="1800" vehsPerHour="329"/>

    <!-- PICO MAXIMO: 30 a 90 min — 100% -->
    <!-- Pino=870  Carranza=470 veh/h    -->
    <flow id="pico_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="1800" end="5400" vehsPerHour="870"/>
    <flow id="pico_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="1800" end="5400" vehsPerHour="870"/>
    <flow id="pico_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="1800" end="5400" vehsPerHour="470"/>
    <flow id="pico_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="1800" end="5400" vehsPerHour="470"/>

    <!-- FIN DE PICO: 90 a 120 min — 85% -->
    <!-- Pino=740  Carranza=400 veh/h    -->
    <flow id="fin_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="5400" end="7200" vehsPerHour="740"/>
    <flow id="fin_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="5400" end="7200" vehsPerHour="740"/>
    <flow id="fin_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="5400" end="7200" vehsPerHour="400"/>
    <flow id="fin_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="5400" end="7200" vehsPerHour="400"/>

</routes>

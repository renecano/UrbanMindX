<?xml version="1.0" encoding="UTF-8"?>
<!--
    hora_pico.rou.xml — v2 CORREGIDA
    Intersección real: Venustiano Carranza × Blvr. Pino Suárez, Toluca
    Fuente: Quivera UAEM 2022 — aforos mayo 2021

    CORRECCIÓN v2: aplicada asimetría real de carriles (3:2 = 60%:40%)
    en cada sentido, igual que normal.rou.xml.

    Simula 2 horas de hora pico con rampa de subida y bajada:
        0-30min  (0-1800s):    inicio de pico  (70% del máximo)
        30-90min (1800-5400s): pico máximo     (100%)
        90-120min(5400-7200s): fin de pico     (85%)

    Flujos máximos fuente UAEM:
        Pino Suárez = 1750 veh/h total sentido
        Carranza    = 940  veh/h total sentido

    Compatible con: hora_pico.sumocfg (begin=0, end=7200)
-->
<routes>

    <vType id="auto_normal"   accel="2.6" decel="4.5" sigma="0.5"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>
    <vType id="auto_autonomo" accel="2.6" decel="4.5" sigma="0.0"
           length="5" minGap="2.5" maxSpeed="13.89" guiShape="passenger"
           color="0,0,255"/>

    <!-- ================================================ -->
    <!-- INICIO DE PICO: 0-30 min (0-1800 s) — 70%      -->
    <!-- Pino Suárez total: 1225 veh/h                   -->
    <!--   Norte (3c, 60%): 735  | Sur  (2c, 40%): 490  -->
    <!-- Carranza total: 658 veh/h                       -->
    <!--   Oeste (3c, 60%): 395  | Este (2c, 40%): 263  -->
    <!-- ================================================ -->
    <flow id="inicio_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="0" end="1800" vehsPerHour="735"/>
    <flow id="inicio_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="0" end="1800" vehsPerHour="490"/>
    <flow id="inicio_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="0" end="1800" vehsPerHour="395"/>
    <flow id="inicio_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="0" end="1800" vehsPerHour="263"/>

    <!-- ================================================ -->
    <!-- PICO MÁXIMO: 30-90 min (1800-5400 s) — 100%    -->
    <!-- Pino Suárez total: 1750 veh/h                   -->
    <!--   Norte (3c, 60%): 1050 | Sur  (2c, 40%): 700  -->
    <!-- Carranza total: 940 veh/h                       -->
    <!--   Oeste (3c, 60%): 564  | Este (2c, 40%): 376  -->
    <!-- ================================================ -->
    <flow id="pico_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="1800" end="5400" vehsPerHour="1050"/>
    <flow id="pico_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="1800" end="5400" vehsPerHour="700"/>
    <flow id="pico_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="1800" end="5400" vehsPerHour="564"/>
    <flow id="pico_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="1800" end="5400" vehsPerHour="376"/>

    <!-- ================================================ -->
    <!-- FIN DE PICO: 90-120 min (5400-7200 s) — 85%    -->
    <!-- Pino Suárez total: 1488 veh/h                   -->
    <!--   Norte (3c, 60%): 893  | Sur  (2c, 40%): 595  -->
    <!-- Carranza total: 799 veh/h                       -->
    <!--   Oeste (3c, 60%): 479  | Este (2c, 40%): 320  -->
    <!-- ================================================ -->
    <flow id="fin_norte" type="auto_normal"
          from="norte_entrada" to="sur_salida"
          begin="5400" end="7200" vehsPerHour="893"/>
    <flow id="fin_sur" type="auto_normal"
          from="sur_entrada" to="norte_salida"
          begin="5400" end="7200" vehsPerHour="595"/>
    <flow id="fin_oeste" type="auto_normal"
          from="oeste_entrada" to="este_salida"
          begin="5400" end="7200" vehsPerHour="479"/>
    <flow id="fin_este" type="auto_normal"
          from="este_entrada" to="oeste_salida"
          begin="5400" end="7200" vehsPerHour="320"/>

</routes>
